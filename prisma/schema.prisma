generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  REGULAR
  PREMIUM
}


enum AuthProvider {
  LOCAL
  GOOGLE
  BOTH
}




model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String?
  name         String?
  lname        String?
  profileURL   String?
  mobileNumber String?     @unique
  googleId     String?     @unique
  location     String?
  dob          DateTime?
  refreshToken String?
  authProvider AuthProvider @default(LOCAL)
  userType     UserType    @default(REGULAR)
  timestamp    DateTime    @default(now())

  feedbacks      Feedback[]
  payment        Payment[]        
  paymentID      String?          @unique

  createdConversations Conversation[] @relation("Creator")
  conversations        ConversationParticipant[]
  convoStates          ConversationByUser[]
  blockedUsers   UserBlock[] @relation("Blocker")
  blockedByUsers UserBlock[] @relation("Blocked")

  @@index([email])
  @@index([mobileNumber])
}


model Feedback {
  id       String   @id @default(uuid())
  userId   String
  title    String
  details  String
  timestamp DateTime @default(now())

  //Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String   
  startTime DateTime?
  endTime   DateTime?
  timestamp DateTime @default(now())


  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Conversation {
  id          String   @id @default(uuid())
  type        String   // 'direct' | 'group'
  creatorId   String
  name        String?
  avatarURL  String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creator     User     @relation("Creator", fields: [creatorId], references: [id])
  participants ConversationParticipant[]
  convoStates  ConversationByUser[]
}


model ConversationParticipant {
  convoId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  conversation Conversation @relation(fields: [convoId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([convoId, userId])
}


model ConversationByUser {
  userId String
  convoId String

  convoName String?
  convoType String?

  lastMessage           String?
  lastMessageSenderId   String?
  lastMessageAt         DateTime?
  lastMessageId         String?

  unreadCount  Int      @default(0)
  lastOpenedAt DateTime?

  isPinned   Boolean @default(false)
  isArchived Boolean @default(false)

  isActive Boolean @default(true)
  leftAt DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [convoId], references: [id], onDelete: Cascade)

  @@id([userId, convoId])
  @@index([userId, isPinned, lastMessageAt(sort: Desc)])
}


model DirectChatLookup {
  pairKey   String   @id
  convoId   String   @unique
  createdAt DateTime @default(now())
}

model MediaFile {
  id        String   @id @db.Uuid
  fileName  String   @map("file_name")
  objectKey String   @unique @map("object_key")
  fileType  String   @map("file_type")
  mimeType  String   @map("mime_type")
  size      BigInt
  chatId    String   @map("chat_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId], map: "idx_media_files_chat_id")
  @@index([fileName], map: "idx_media_files_file_name")
  @@map("media_files")
}

model Admin {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  name     String?
}

model UserBlock {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}
