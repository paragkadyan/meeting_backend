generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  REGULAR
  PREMIUM
}


enum AuthProvider {
  LOCAL
  GOOGLE
  BOTH
}




model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String?
  name         String?
  lname        String?
  profileURL   String?
  mobileNumber String?     @unique
  googleId     String?     @unique
  location     String?
  dob          DateTime?
  refreshToken String?
  authProvider AuthProvider @default(LOCAL)
  userType     UserType    @default(REGULAR)
  timestamp    DateTime    @default(now())

  feedbacks      Feedback[]
  payment        Payment[]        
  paymentID      String?          @unique

  @@index([email])
  @@index([mobileNumber])
}


model Feedback {
  id       String   @id @default(uuid())
  userID   String
  title    String
  details  String
  timestamp DateTime @default(now())

  //Relations
  user User @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID])
}

model Payment {
  id        String   @id @default(uuid())
  userID    String   
  startTime DateTime?
  endTime   DateTime?
  timestamp DateTime @default(now())


  user      User     @relation(fields: [userID], references: [id])

  @@index([userID])
}